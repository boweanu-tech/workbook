}

\newcommand{\MajorQuestionLesson}[1]{%
  \ResetRowSpace
  \stepcounter{LMmajor}%
  \setcounter{LMtype}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
  \ifLMAnswerMode
    \ifLMInAnswerBlock\end{minipage}\par\vspace{2mm}\fi
    \noindent\begin{minipage}{\linewidth}
    \LMInAnswerBlocktrue
    \noindent\LMBoxedMajor\par\vspace{1.5mm}%
  \else
    \clearpage
    \noindent\LMBoxedMajorLesson\quad \raisebox{-1mm}{\Large #1}\par
    \vspace{2mm}\hrule height \LMRuleWidth\vspace{4mm}%
  \fi
}

\newcommand{\MajorQuestion}[1]{%
  \ResetRowSpace
  \stepcounter{LMmajor}%
  \setcounter{LMtype}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
  \ifLMAnswerMode
    \ifLMInAnswerBlock\end{minipage}\par\vspace{2mm}\fi
    \noindent\begin{minipage}{\linewidth}
    \LMInAnswerBlocktrue
    \noindent\LMBoxedMajor\par\vspace{1.5mm}%
  \else
    \clearpage
    \noindent\LMBoxedMajor\quad \raisebox{-0.4mm}{#1}\par
    \vspace{2mm}\hrule height \LMRuleWidth\vspace{4mm}%
  \fi
}

% lesson_用の大問見出し。呼び出すたびに大問番号を進め、小問番号を(1)からに戻す。
% 例: \TypeQuestion{平方根の形にする}
\newcommand{\TypeQuestion}[2]{%
  \stepcounter{LMtype}%
  \setcounter{LMsubq}{0}%
  \ifLMInstructionUsed
    \par\vspace{7mm}%
  \fi
  \LMInstructionUsedtrue
  \ifLMAnswerMode
    \noindent
    \begin{minipage}[t]{10mm}%
      \vspace{0pt}\LMBoxedTypeQuestionAns%
    \end{minipage}%
    \par\vspace{4mm}%
  \else
    \noindent
    \begin{minipage}[t]{10mm}%
      \vspace{0pt}\LMBoxedTypeQuestion%
    \end{minipage}%
    \hspace{2mm}%
    \begin{minipage}[t]{\dimexpr\linewidth-12mm\relax}%
      \vspace{#2}#1%
    \end{minipage}%
    \par
    \vspace{6mm}%
  \fi
}

%1行用
\newcommand{\TypeQuestionSingle}[2]{
\TypeQuestion{#1}{2.8mm}
}

%2行用
\newcommand{\TypeQuestionDouble}[2]{
\TypeQuestion{#1}{0.2mm}
}




