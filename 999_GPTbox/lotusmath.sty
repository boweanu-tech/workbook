\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lotusmath}[2026/06/22 minimal math test package v28]

\usepackage{amssymb}

\newlength{\LMRuleWidth}
\setlength{\LMRuleWidth}{0.8pt}
\newlength{\LMDefaultRowSpace}
\setlength{\LMDefaultRowSpace}{4mm}
\newlength{\LMCalcRowSpace}
\setlength{\LMCalcRowSpace}{16mm}
\newlength{\LMQandaRowSpace}
\setlength{\LMQandaRowSpace}{1mm}
\newlength{\LMAnswerRowSpace}
\setlength{\LMAnswerRowSpace}{3mm}
\newlength{\LMRowSpace}
\setlength{\LMRowSpace}{\LMDefaultRowSpace}
\newlength{\LMFigureRowSpace}
\setlength{\LMFigureRowSpace}{12mm}

\RequirePackage{geometry}
\RequirePackage{multicol}
\RequirePackage[dvipdfmx]{graphicx}
\RequirePackage{wrapfig}
\geometry{b5paper,top=16mm,bottom=16mm,left=16mm,right=16mm}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\setlength{\fboxrule}{\LMRuleWidth}

\makeatletter
\newif\ifLMAnswerMode
\LMAnswerModefalse
\newif\ifLMInAnswerBlock
\LMInAnswerBlockfalse
\newif\ifLMInstructionUsed
\LMInstructionUsedfalse
\newif\ifLMWrapMode
\LMWrapModefalse

\newcounter{LMmajor}
\newcounter{LMsubq}
\newcommand{\LMCurrentTheme}{}
\newcommand{\LMCoverTitle}{}
\newcommand{\LMCoverSubtitle}{}
\newcommand{\LMCurrentProblemDir}{./}

\newsavebox{\LMMeasureBox}
\newlength{\LMAnswerHeight}
\newif\ifLMTallAnswer

\newcommand{\LMSetProblemDir}[1]{%
  \filename@parse{#1}%
  \xdef\LMCurrentProblemDir{\filename@area}%
  \ifx\LMCurrentProblemDir\@empty
    \graphicspath{{./}}%
  \else
    \graphicspath{{\LMCurrentProblemDir}{./}}%
  \fi
}

\newcommand{\LMProblemList}{}
\newcommand{\Use}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2.tex}%
  \input{#1_#2.tex}%
  \g@addto@macro\LMProblemList{\LMAnswerInput{#1}{#2}}%
}
\newcommand{\LMAnswerInput}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2.tex}%
  \input{#1_#2.tex}%
}

\newcommand{\CoverPage}[2]{%
  \gdef\LMCoverTitle{#1}%
  \gdef\LMCoverSubtitle{#2}%
  \begin{titlepage}
  \thispagestyle{empty}
  \vspace*{20mm}
  {\large 名前\quad\underline{\hspace{80mm}}}\par
  \vspace{35mm}
  \begin{center}
    {\Huge 総まとめテスト}\par
    \vspace{12mm}
    {\LARGE #1}\par
    \vspace{18mm}
    {\large #2}\par
  \end{center}
  \end{titlepage}
}

\newcommand{\BeginQuestions}{%
  \LMAnswerModefalse
  \setcounter{LMmajor}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
}

\newcommand{\BeginAnswers}{%
  \clearpage
  \LMAnswerModetrue
  \setcounter{LMmajor}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
  \begin{center}
    {\Large \LMCoverTitle}\par
    \vspace{1mm}
    {\normalsize \LMCoverSubtitle}\par
  \end{center}
  \vspace{3mm}
  \begin{multicols}{2}
  \raggedcolumns
  \LMInAnswerBlockfalse
}

\newcommand{\PrintAnswers}{%
  \BeginAnswers
  \LMProblemList
  \ifLMInAnswerBlock\end{minipage}\par\LMInAnswerBlockfalse\fi
  \end{multicols}
}

\newcommand{\LMPrintedMajor}{\LMCurrentTheme}
\newcommand{\LMBoxedMajor}{%
  {\setlength{\fboxsep}{0pt}%
   \fbox{\parbox[c][7mm][c]{7mm}{\centering\large\LMPrintedMajor}}}%
}

\newcommand{\SetRowSpace}[1]{%
  \setlength{\LMRowSpace}{#1}%
}
\newcommand{\SetRowSpaceCalc}{%
  \setlength{\LMRowSpace}{\LMCalcRowSpace}%
}
\newcommand{\SetRowSpaceQanda}{%
  \setlength{\LMRowSpace}{\LMQandaRowSpace}%
}

\newcommand{\Blank}[1]{【\quad #1\quad 】}
\newcommand{\NamedBlank}[1]{%
  \expandafter\xdef\csname LMBlankNumber:#1\endcsname{\theLMsubq}%
  \Blank{\theLMsubq}%
}
\newcommand{\RefBlank}[1]{%
  \expandafter\ifx\csname LMBlankNumber:#1\endcsname\relax
    \Blank{??}%
  \else
    \Blank{\csname LMBlankNumber:#1\endcsname}%
  \fi
}

\newcommand{\LMFig}[2][0.7\linewidth]{%
  \begin{center}%
    \includegraphics[width=#1]{#2}%
  \end{center}%
}
\newcommand{\LMFigInline}[2][0.7\linewidth]{%
  \includegraphics[width=#1]{#2}%
}
\newcommand{\LMFigBlock}[2][0.7\linewidth]{%
  {\centering\includegraphics[width=#1]{#2}\par}%
}

\newcommand{\ResetRowSpace}{%
  \setlength{\LMRowSpace}{\LMDefaultRowSpace}%
}

\newcommand{\MajorQuestion}[1]{%
  \ResetRowSpace
  \stepcounter{LMmajor}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
  \ifLMAnswerMode
    \ifLMInAnswerBlock\end{minipage}\par\vspace{2mm}\fi
    \noindent\begin{minipage}{\linewidth}
    \LMInAnswerBlocktrue
    \noindent\LMBoxedMajor\par\vspace{1.5mm}%
  \else
    \clearpage
    \noindent\LMBoxedMajor\quad \raisebox{-0.4mm}{#1}\par
    \vspace{2mm}\hrule height \LMRuleWidth\vspace{4mm}%
  \fi
}

\newcommand{\Instruction}[1]{%
  \ifLMInstructionUsed
    \par\vspace{7mm}%
  \fi
  \LMInstructionUsedtrue
  \ifLMAnswerMode
    \par\vspace{1mm}%
  \else
    \noindent #1\par
    \vspace{6mm}%
  \fi
}

\newcommand{\Text}[1]{%
  \ifLMAnswerMode
  \else
    \noindent #1\par\vspace{1mm}%
    \vspace{\LMDefaultRowSpace}%
  \fi
}

\newcommand{\LMMeasureAnswer}[2]{%
  \sbox{\LMMeasureBox}{\parbox[t]{#1}{#2}}%
  \setlength{\LMAnswerHeight}{\dimexpr\ht\LMMeasureBox+\dp\LMMeasureBox\relax}%
  \LMTallAnswerfalse
  \ifdim\LMAnswerHeight>15pt
    \LMTallAnswertrue
  \fi
}

\newcommand{\LMPrintAnswer}[3]{%
  \LMMeasureAnswer{#1}{#3}%
  \ifLMTallAnswer
    \parbox[t]{\dimexpr\linewidth-#2\relax}{%
      \setlength{\baselineskip}{1.45\baselineskip}%
      #3%
    }%
    \par\vspace{3mm}%
  \else
    \parbox[t]{\dimexpr\linewidth-#2\relax}{#3}%
    \par\vspace{3mm}%
  \fi
}

\newcommand{\Q}[3]{%
  \stepcounter{LMsubq}%
  \noindent
  \makebox[11mm][l]{(\theLMsubq)}%
  \ifLMAnswerMode
    \LMPrintAnswer{\dimexpr\linewidth-11mm\relax}{11mm}{#2}%
  \else
    \parbox[t]{\dimexpr\linewidth-11mm\relax}{#1}%
    \par\vspace{#3}%
  \fi
}

\newcommand{\WrapFig}{\@ifnextchar[{\LMWrapFigRows}{\LMWrapFigAuto}}
\newcommand{\LMWrapFigAuto}[4]{%
  \ifLMAnswerMode
    #4%
  \else
    \par\noindent
    \begin{wrapfigure}{#1}{#2}
      \vspace{-\baselineskip}%
      \centering
      \includegraphics[width=\linewidth]{#3}%
      \vspace{-\baselineskip}%
    \end{wrapfigure}%
    \LMWrapModetrue
    #4\par
    \LMWrapModefalse
    \vspace{\LMFigureRowSpace}%
  \fi
}
\newcommand{\LMWrapFigRows}[5][]{%
  \ifLMAnswerMode
    #5%
  \else
    \par\noindent
    \begin{wrapfigure}[#1]{#2}{#3}
      \vspace{-\baselineskip}%
      \centering
      \includegraphics[width=\linewidth]{#4}%
      \vspace{-\baselineskip}%
    \end{wrapfigure}%
    \LMWrapModetrue
    #5\par
    \LMWrapModefalse
    \vspace{\LMFigureRowSpace}%
  \fi
}

\newcommand{\BeginTwoCols}{\par\vspace{2mm}}
\newcommand{\EndTwoCols}{\par}

\newcommand{\QQ}[2]{%
  \stepcounter{LMsubq}%
  \noindent
  \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
  \ifLMAnswerMode
    \LMPrintAnswer{\dimexpr\linewidth-9mm\relax}{9mm}{#2}%
  \else
    \ifLMWrapMode
      {\hangindent=9mm\hangafter=1 #1\par}%
      \vspace{\LMRowSpace}%
    \else
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#1}%
      \par\vspace{\LMRowSpace}%
    \fi
  \fi
}

\newcommand{\QQTall}[2]{%
  \stepcounter{LMsubq}%
  \noindent
  \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
  \ifLMAnswerMode
    \LMPrintAnswer{\dimexpr\linewidth-9mm\relax}{9mm}{#2}%
  \else
    \ifLMWrapMode
      {\setlength{\baselineskip}{1.25\baselineskip}%
       \hangindent=9mm\hangafter=1 #1\par}%
      \vspace{\LMRowSpace}%
    \else
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{%
        \setlength{\baselineskip}{1.25\baselineskip}%
        #1\par
      }%
      \par\vspace{\LMRowSpace}%
    \fi
  \fi
}

\newcommand{\QQRow}[4]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \ifLMAnswerMode
      \LMMeasureAnswer{\dimexpr\linewidth-9mm\relax}{#2}%
      \ifLMTallAnswer
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{\setlength{\baselineskip}{1.45\baselineskip}#2}%
      \else
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{#2}%
      \fi
    \else
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#1}%
    \fi
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \ifLMAnswerMode
      \LMMeasureAnswer{\dimexpr\linewidth-9mm\relax}{#4}%
      \ifLMTallAnswer
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{\setlength{\baselineskip}{1.45\baselineskip}#4}%
      \else
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{#4}%
      \fi
    \else
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#3}%
    \fi
  \end{minipage}%
  \ifLMAnswerMode
    \par\vspace{\LMAnswerRowSpace}%
  \else
    \par\vspace{\LMRowSpace}%
  \fi
}

\newcommand{\QQFigRow}[7][0.9\linewidth]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \ifLMAnswerMode
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \LMMeasureAnswer{\dimexpr\linewidth-9mm\relax}{#4}%
      \ifLMTallAnswer
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{\setlength{\baselineskip}{1.45\baselineskip}#4}%
      \else
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{#4}%
      \fi
    \else
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#3}%
      \par\vspace{1mm}%
      \LMFigBlock[#1]{#2}%
    \fi
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \ifLMAnswerMode
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \LMMeasureAnswer{\dimexpr\linewidth-9mm\relax}{#7}%
      \ifLMTallAnswer
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{\setlength{\baselineskip}{1.45\baselineskip}#7}%
      \else
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{#7}%
      \fi
    \else
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#6}%
      \par\vspace{1mm}%
      \LMFigBlock[#1]{#5}%
    \fi
  \end{minipage}%
  \ifLMAnswerMode
    \par\vspace{\LMAnswerRowSpace}%
  \else
    \par\vspace{\LMFigureRowSpace}%
  \fi
}

\newcommand{\QQSingle}[2]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \ifLMAnswerMode
      \LMMeasureAnswer{\dimexpr\linewidth-9mm\relax}{#2}%
      \ifLMTallAnswer
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{\setlength{\baselineskip}{1.45\baselineskip}#2}%
      \else
        \parbox[t]{\dimexpr\linewidth-9mm\relax}{#2}%
      \fi
    \else
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#1}%
    \fi
  \end{minipage}%
  \ifLMAnswerMode
    \par\vspace{\LMAnswerRowSpace}%
  \else
    \par\vspace{\LMRowSpace}%
  \fi
}

\newcommand{\MakeEvenPage}{%
  \clearpage
  \ifodd\value{page}%
    \null\thispagestyle{empty}\clearpage
  \fi
}
\makeatother
