\newcommand{\QQ}[2]{%
  \ifLMWrapMode
    \LMQQWrap{#1}{#2}%
  \else
    \LMQQNormal{#1}{#2}%
  \fi
}

\newcommand{\LMQQNormal}[2]{%
  \noindent
  \stepcounter{LMsubq}%
  \ifLMAnswerMode
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \LMAnswerParbox{\dimexpr\linewidth-9mm\relax}{#2}%
    \par\vspace{\LMAnswerRowSpace}%
  \else
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \begin{minipage}[t]{\dimexpr\linewidth-9mm\relax}%
      \vspace{0pt}#1%
    \end{minipage}%
    \par\vspace{\LMRowSpace}%
  \fi
}

\newcommand{\QQRow}[4]{%
  \ifLMAnswerMode
    \noindent
    \begin{minipage}[t]{\dimexpr0.5\linewidth-0.5mm\relax}
      \stepcounter{LMsubq}%
      \makebox[\LMAnsLabelWidth][l]{\textbf{(\theLMsubq)}}%
      \LMFitInlineAnswer{\dimexpr\linewidth-\LMAnsLabelWidth\relax}{#2}%
    \end{minipage}%
    \hspace{1mm}%
    \begin{minipage}[t]{\dimexpr0.5\linewidth-0.5mm\relax}
      \stepcounter{LMsubq}%
      \makebox[\LMAnsLabelWidth][l]{\textbf{(\theLMsubq)}}%
      \LMFitInlineAnswer{\dimexpr\linewidth-\LMAnsLabelWidth\relax}{#4}%
    \end{minipage}%
    \par\vspace{\LMAnswerRowSpace}%
  \else
    \noindent
    \begin{minipage}[t]{0.48\linewidth}
      \stepcounter{LMsubq}%
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#1}%
    \end{minipage}%
    \hfill
    \begin{minipage}[t]{0.48\linewidth}
      \stepcounter{LMsubq}%
      \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
      \parbox[t]{\dimexpr\linewidth-9mm\relax}{#3}%
    \end{minipage}%
    \par\vspace{\LMRowSpace}%
  \fi
}

\newcommand{\QQRowFig}[6]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \parbox[t]{\dimexpr\linewidth-9mm\relax}{%
      #1\par\vspace{1mm}%
      \LMFigInline[#3]{#2}%
    }%
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \parbox[t]{\dimexpr\linewidth-9mm\relax}{%
      #4\par\vspace{1mm}%
      \LMFigInline[#6]{#5}%
    }%
  \end{minipage}%
  \par\vspace{\LMFigureRowSpace}%
}

\newcommand{\QQRowFigSingle}[3]{%
  \noindent
  \stepcounter{LMsubq}%
  \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
  \begin{minipage}[t]{\dimexpr\linewidth-9mm\relax}%
    \vspace{0pt}#1\par\vspace{1mm}%
    \LMFig[#3]{#2}%
  \end{minipage}%
  \par\vspace{\LMFigureRowSpace}%
}

\newcommand{\QQFigSideBySide}[6]{%
  \noindent
  \stepcounter{LMsubq}%
  \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
  \begin{minipage}[t]{\dimexpr\linewidth-9mm\relax}%
    \vspace{0pt}#1\par\vspace{1mm}%
    \begin{minipage}[t]{\dimexpr0.5\linewidth-0.5\LMFigSideGap\relax}
      \centering\includegraphics[width=#3]{#2}
    \end{minipage}%
    \hspace{\LMFigSideGap}%
    \begin{minipage}[t]{\dimexpr0.5\linewidth-0.5\LMFigSideGap\relax}
      \centering\includegraphics[width=#6]{#5}
    \end{minipage}%
  \end{minipage}%
  \par\vspace{\LMFigureRowSpace}%
}

