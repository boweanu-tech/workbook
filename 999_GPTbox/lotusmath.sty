\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lotusmath}[2026/06/08 minimal math test package v14]

\usepackage{amssymb}

\RequirePackage{geometry}
\RequirePackage{multicol}
\geometry{b5paper,top=16mm,bottom=16mm,left=16mm,right=16mm}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\setlength{\fboxrule}{1pt}

\makeatletter
\newif\ifLMAnswerMode
\LMAnswerModefalse
\newif\ifLMInAnswerBlock
\LMInAnswerBlockfalse
\newif\ifLMInstructionUsed
\LMInstructionUsedfalse

\newcounter{LMmajor}
\newcounter{LMsubq}
\newcommand{\LMCurrentTheme}{}

% 問題ファイル一覧を蓄積する。
% 使用例: \Use{../001_math/23_2_roots/test}{01}
%         -> ../001_math/23_2_roots/test_01.tex を読み込み、テーマ番号 01 を表示する。
\newcommand{\LMProblemList}{}
\newcommand{\Use}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \input{#1_#2.tex}%
  \g@addto@macro\LMProblemList{\LMAnswerInput{#1}{#2}}%
}
\newcommand{\LMAnswerInput}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \input{#1_#2.tex}%
}

\newcommand{\CoverPage}[2]{%
  \begin{titlepage}
  \thispagestyle{empty}
  \vspace*{20mm}
  {\large 名前\quad\underline{\hspace{80mm}}}\par
  \vspace{35mm}
  \begin{center}
    {\Huge 総まとめテスト}\par
    \vspace{12mm}
    {\LARGE #1}\par
    \vspace{18mm}
    {\large #2}\par
  \end{center}
  \end{titlepage}
}

\newcommand{\BeginQuestions}{%
  \LMAnswerModefalse
  \setcounter{LMmajor}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
}

\newcommand{\BeginAnswers}{%
  \clearpage
  \LMAnswerModetrue
  \setcounter{LMmajor}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \begin{center}{\Large 解答}\end{center}
  \vspace{3mm}
  \begin{multicols}{2}
  \raggedcolumns
  \LMInAnswerBlockfalse
}

\newcommand{\PrintAnswers}{%
  \BeginAnswers
  \LMProblemList
  \ifLMInAnswerBlock\end{minipage}\par\LMInAnswerBlockfalse\fi
  \end{multicols}
}

\newcommand{\LMPrintedMajor}{\LMCurrentTheme}

\newcommand{\LMBoxedMajor}{%
  {\setlength{\fboxsep}{0pt}%
   \fbox{\parbox[c][9mm][c]{9mm}{\centering\large\LMPrintedMajor}}}%
}

\newcommand{\MajorQuestion}[1]{%
  \stepcounter{LMmajor}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \ifLMAnswerMode
    \ifLMInAnswerBlock\end{minipage}\par\vspace{2mm}\fi
    \noindent\begin{minipage}{\linewidth}
    \LMInAnswerBlocktrue
    \noindent\LMBoxedMajor\par\vspace{1.5mm}%
  \else
    \clearpage
    \noindent\LMBoxedMajor\quad #1\par
    \vspace{2mm}\hrule\vspace{4mm}%
  \fi
}

% 大問内で追加の指示文を表示する。改ページせず、小問番号も維持する。
% 1回目の指示文には上余白を入れず、2回目以降の指示文の前だけ余白を入れる。
\newcommand{\Instruction}[1]{%
  \ifLMInstructionUsed
    \par\vspace{7mm}%
  \fi
  \LMInstructionUsedtrue
  \ifLMAnswerMode
    \par\vspace{1mm}%
  \else
    \noindent #1\par
    \vspace{6mm}%
  \fi
}

\newcommand{\Q}[3]{%
  \stepcounter{LMsubq}%
  \noindent
  \makebox[11mm][l]{(\theLMsubq)}%
  \parbox[t]{\dimexpr\linewidth-11mm\relax}{\ifLMAnswerMode #2\else #1\fi}%
  \par
  \ifLMAnswerMode\vspace{3.4ex}\else\vspace{#3}\fi
}

% 旧2列配置用。単一列の互換命令として残す。
\newcommand{\BeginTwoCols}{\par\vspace{2mm}}
\newcommand{\EndTwoCols}{\par}
\newcommand{\QQ}[2]{%
  \stepcounter{LMsubq}%
  \noindent
  \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
  \parbox[t]{\dimexpr\linewidth-9mm\relax}{\ifLMAnswerMode #2\else #1\fi}%
  \par\vspace{10mm}%
}

% 2問を横並びで出力する。番号は左から右へ進む。
% \QQRow{左問題}{左解答}{右問題}{右解答}
\newcommand{\QQRow}[4]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \parbox[t]{\dimexpr\linewidth-9mm\relax}{\ifLMAnswerMode #2\else #1\fi}%
  \end{minipage}%
  \hfill
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \parbox[t]{\dimexpr\linewidth-9mm\relax}{\ifLMAnswerMode #4\else #3\fi}%
  \end{minipage}%
  \par\vspace{10mm}%
}

% 1問だけ残る場合に使う。
\newcommand{\QQSingle}[2]{%
  \noindent
  \begin{minipage}[t]{0.48\linewidth}
    \stepcounter{LMsubq}%
    \makebox[9mm][l]{\textbf{(\theLMsubq)}}%
    \parbox[t]{\dimexpr\linewidth-9mm\relax}{\ifLMAnswerMode #2\else #1\fi}%
  \end{minipage}%
  \par\vspace{10mm}%
}

\newcommand{\MakeEvenPage}{%
  \clearpage
  \ifodd\value{page}%
    \null\thispagestyle{empty}\clearpage
  \fi
}
\makeatother
