\newcommand{\LMFitAnswer}[2]{%
  \begingroup
  \setlength{\LMFitAnswerWidth}{#1}%
  \sbox{\LMMeasureBox}{#2}%
  \ifdim\wd\LMMeasureBox<\LMFitAnswerWidth
    #2%
  \else
    \sbox{\LMMeasureBox}{{\small #2}}%
    \ifdim\wd\LMMeasureBox<\LMFitAnswerWidth
      {\small #2}%
    \else
      \sbox{\LMMeasureBox}{{\scriptsize #2}}%
      \ifdim\wd\LMMeasureBox<\LMFitAnswerWidth
        {\scriptsize #2}%
      \else
        \resizebox{\LMFitAnswerWidth}{!}{{\scriptsize #2}}%
      \fi
    \fi
  \fi
  \endgroup
}
\newsavebox{\LMAnsFitBox}
\newlength{\LMAnsFitWidth}
\newlength{\LMAnsLabelWidth}
\setlength{\LMAnsLabelWidth}{6.5mm}

\newcommand{\LMFitInlineAnswer}[2]{%
  \begingroup
  \setlength{\LMAnsFitWidth}{#1}%
  \sbox{\LMAnsFitBox}{#2}%
  \ifdim\wd\LMAnsFitBox>\LMAnsFitWidth
    \sbox{\LMAnsFitBox}{{\small #2}}%
    \ifdim\wd\LMAnsFitBox>\LMAnsFitWidth
      \sbox{\LMAnsFitBox}{{\scriptsize #2}}%
      \ifdim\wd\LMAnsFitBox>\LMAnsFitWidth
        \makebox[\LMAnsFitWidth][l]{%
          \resizebox{\LMAnsFitWidth}{!}{\usebox{\LMAnsFitBox}}%
        }%
      \else
        \makebox[\LMAnsFitWidth][l]{\usebox{\LMAnsFitBox}}%
      \fi
    \else
      \makebox[\LMAnsFitWidth][l]{\usebox{\LMAnsFitBox}}%
    \fi
  \else
    \makebox[\LMAnsFitWidth][l]{\usebox{\LMAnsFitBox}}%
  \fi
  \endgroup
}

\newcommand{\LMAnswerParbox}[2]{%
  \parbox[t]{#1}{%
    \raggedright
    \LMFitAnswer{#1}{#2}%
    \par
  }%
}

\newcommand{\LMSetProblemDir}[1]{%
  \filename@parse{#1}%
  \xdef\LMCurrentProblemDir{\filename@area}%
  \ifx\LMCurrentProblemDir\@empty
    \graphicspath{{./}}%
  \else
    \graphicspath{{\LMCurrentProblemDir}{./}}%
  \fi
}

\newcommand{\LMProblemList}{}
\newcommand{\Use}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2.tex}%
  \input{#1_#2.tex}%
  \g@addto@macro\LMProblemList{\LMAnswerInput{#1}{#2}}%
}

\newcommand{\UseREF}[3]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2#3.tex}%
  \input{#1_#2#3.tex}%
  \g@addto@macro\LMProblemList{\LMAnswerInputREF{#1}{#2}{#3}}%
}

\newcommand{\LMAnswerInput}[2]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2.tex}%
  \input{#1_#2.tex}%
}

\newcommand{\LMAnswerInputREF}[3]{%
  \gdef\LMCurrentTheme{#2}%
  \LMSetProblemDir{#1_#2#3.tex}%
  \input{#1_#2#3.tex}%
}

\newcommand{\CoverPage}[2]{%
  \gdef\LMCoverTitle{#1}%
  \gdef\LMCoverSubtitle{#2}%
  \begin{titlepage}
  \thispagestyle{empty}
  \vspace*{20mm}
  {\large 名前\quad\underline{\hspace{80mm}}}\par
  \vspace{35mm}
  \begin{center}
    {\Huge 総まとめテスト}\par
    \vspace{12mm}
    {\LARGE #1}\par
    \vspace{18mm}
    {\large #2}\par
  \end{center}
  \end{titlepage}
}

\newcommand{\CoverPageLesson}[2]{%
\CoverPage{#1}{#2}
  \clearpage
  \null
  \thispagestyle{empty}%
  \clearpage
}

\newcommand{\BeginQuestions}{%
  \LMAnswerModefalse
  \setcounter{LMmajor}{0}%
  \setcounter{LMtype}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
}

\newcommand{\BeginAnswers}{%
  \clearpage
  \LMAnswerModetrue
  \setcounter{LMmajor}{0}%
  \setcounter{LMtype}{0}%
  \setcounter{LMsubq}{0}%
  \LMInstructionUsedfalse
  \LMWrapModefalse
  \begin{center}
    {\Large \LMCoverTitle}\par
    \vspace{1mm}
    {\normalsize \LMCoverSubtitle}\par
  \end{center}
  \vspace{3mm}
  \begin{multicols}{2}
  \raggedcolumns
  \LMInAnswerBlockfalse
}

\newcommand{\PrintAnswers}{%
  \BeginAnswers
  \LMProblemList
  \ifLMInAnswerBlock\end{minipage}\par\LMInAnswerBlockfalse\fi
  \end{multicols}
}

